# ===========================================
# DermaAssistAI Environment Variables
# ===========================================

# Database Configuration
# Neon PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# AI API Keys
# OpenAI API key for GPT-5.5 model
OPENAI_API_KEY=your_openai_api_key_here
# Optional: override the default OpenAI diagnosis model
OPENAI_MODEL=gpt-5.5

# Google Gemini API key for Gemini-2.5-flash model
GEMINI_API_KEY=your_gemini_api_key_here
# Alternative variable name for Gemini
GOOGLE_API_KEY=your_gemini_api_key_here

# Server Configuration
# Port for the application (default: 5000)
PORT=3000

# Environment mode
NODE_ENV=development

# Session Configuration
# Secret key for session management (generate a random string)
SESSION_SECRET=your_session_secret_key_here_change_this_to_random_string

# JWT Configuration
# In production, set both JWT secrets explicitly.
JWT_SECRET=your_jwt_secret_here_change_this_to_random_string
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_change_this_to_another_random_string

# Local password login is development-only by default.
# In production, prefer Google OAuth. Enable only if you also set the email/password below.
LOCAL_AUTH_ENABLED=false
LOCAL_AUTH_EMAIL=admin@yourdomain.com
LOCAL_AUTH_PASSWORD=change_this_to_a_strong_password

# File Upload Configuration
# Directory for uploaded files (local file storage)
UPLOAD_DIR=./uploads

# Application Configuration
# Admin email address (first user with this email becomes admin)
ADMIN_EMAIL=admin@yourdomain.com

# ===========================================
# Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual keys/URLs
# 3. Never commit .env file to version control
# ===========================================
