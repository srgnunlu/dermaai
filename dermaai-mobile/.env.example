# Mobile app public configuration
# Copy to .env for local Expo development or configure in EAS build profiles.

# Backend API URL
# iOS simulator can usually use http://localhost:5000.
# Android emulator usually needs http://10.0.2.2:5000.
# Physical devices need your computer's LAN IP, for example http://192.168.1.20:5000.
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# Google OAuth client IDs
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_web_or_mobile_google_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_google_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_google_client_id.apps.googleusercontent.com

# RevenueCat public SDK keys
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your_revenuecat_ios_public_key
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your_revenuecat_android_public_key
